<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title><%= recipe.title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <nav class="nav">
      <a href="/">Home</a>
      <a href="/recipes">Recipes</a>
      <a href="/add-recipe">Add Recipe</a>
    </nav>

    <main class="container">
      <h1><%= recipe.title %></h1>
      <p><strong>Category:</strong> <%= recipe.protein_type %></p>

      <h2>Ingredients (hover for info)</h2>

      <ul class="ingredient-list">
        <% ingredients.forEach(ingredient => { %>
          <li class="ingredient" data-ingredient-id="<%= ingredient.id %>">
            <%= ingredient.name %>
          </li>
        <% }) %>
      </ul>

      <% if (recipe.instructions && recipe.instructions.trim().length > 0) { %>
        <h2>Instructions</h2>
        <p style="white-space: pre-line;"><%= recipe.instructions %></p>
      <% } %>

      <p>
        <a href="/recipes">← Back to Recipes</a>
      </p>
    </main>

    <div id="tooltip" class="tooltip hidden"></div>
    <script src="/script.js"></script>
  </body>
</html>